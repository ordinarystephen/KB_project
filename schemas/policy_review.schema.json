{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy Completeness Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviewed_extraction", "missing_rules", "missing_thresholds", "missing_approval_requirements", "missing_documentation_requirements", "weak_source_references", "ambiguous_rules", "rules_needing_split", "rules_needing_policy_owner_review", "non_checkable_rules", "rules_missing_conditions", "rules_missing_fields", "ready_for_consolidation", "usable_for_credit_documentation_checks", "processing_summary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewed_extraction": {"type": "string", "minLength": 1},
    "missing_rules": {"type": "array"},
    "missing_thresholds": {"type": "array"},
    "missing_approval_requirements": {"type": "array"},
    "missing_documentation_requirements": {"type": "array"},
    "weak_source_references": {"type": "array"},
    "ambiguous_rules": {"type": "array"},
    "rules_needing_split": {"type": "array"},
    "rules_needing_policy_owner_review": {"type": "array"},
    "non_checkable_rules": {"type": "array"},
    "rules_missing_conditions": {"type": "array"},
    "rules_missing_fields": {"type": "array"},
    "ready_for_consolidation": {"type": "boolean"},
    "usable_for_credit_documentation_checks": {"type": "boolean"},
    "processing_summary": {
      "type": "object",
      "required": ["main_takeaways", "potential_gaps", "high_priority_reviewer_issues", "ready_for_consolidation", "usable_for_credit_documentation_checks", "recommended_next_steps"]
    }
  }
}
